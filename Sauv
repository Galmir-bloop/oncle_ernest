.banniere {
    position: relative;
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1000px;
    margin: 0 auto;
    padding: 0;  
}

.bloc-titre {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
}

.sous-titre {
    font-family: "Special Elite", cursive;
    font-size: 12px;
    color: #3c3c3c;
    font-style: italic;
    letter-spacing: 1px;
    margin: 2px 0 0 0;
    line-height: 1;
}